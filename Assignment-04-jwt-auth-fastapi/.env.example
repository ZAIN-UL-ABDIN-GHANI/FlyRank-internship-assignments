# Secret key used to sign JWTs. Generate a strong random value in production,
# e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# JWT signing algorithm
JWT_ALGORITHM=HS256

# How long an access token stays valid, in minutes
JWT_EXPIRE_MINUTES=60

# Database connection string (SQLite by default, works with zero setup)
DATABASE_URL=sqlite:///./app.db

# bcrypt cost factor (higher = slower/more secure, 12 is a solid default)
BCRYPT_ROUNDS=12
