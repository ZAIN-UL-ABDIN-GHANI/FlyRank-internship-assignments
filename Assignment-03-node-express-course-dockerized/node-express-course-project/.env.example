# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (used both by the app and by docker-compose to boot the postgres-db container)
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Full connection string the app actually uses.
# - Running the app via `docker compose up`: host must be the service name "postgres-db"
# - Running the app locally against `docker compose up postgres-db` only: host is "localhost"
DATABASE_URL=postgres://postgres:postgres@localhost:5432/appdb

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Misc
API_KEY=replace_this_with_your_api_key
